<?xml version="1.0" encoding="utf-8"?>
<Package xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop5="http://schemas.microsoft.com/appx/manifest/desktop/windows10/5"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap10 desktop4 desktop5 com rescap">

  <Identity Name="Zophie.Sticker"
    ProcessorArchitecture="x64"
    Publisher="CN=Zophie"
    Version="1.0.4.0" />

  <Properties>
    <DisplayName>Sticker</DisplayName>
    <PublisherDisplayName>Zophie</PublisherDisplayName>
    <Logo>app.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
      MinVersion="10.0.22000.0"
      MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-au" />
  </Resources>

  <Applications>
    <Application Id="Sticker" Executable="Sticker.exe"
      uap10:TrustLevel="mediumIL" uap10:RuntimeBehavior="win32App">
      <uap:VisualElements DisplayName="Sticker"
        Description="Floating image cutouts"
        BackgroundColor="transparent"
        Square150x150Logo="app.png"
        Square44x44Logo="app.png"
        AppListEntry="none" />
      <Extensions>

        <desktop4:Extension Category="windows.fileExplorerContextMenus">
          <desktop4:FileExplorerContextMenus>
            <desktop5:ItemType Type=".jpg">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
            <desktop5:ItemType Type=".jpeg">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
            <desktop5:ItemType Type=".png">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
            <desktop5:ItemType Type=".webp">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
            <desktop5:ItemType Type=".bmp">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
            <desktop5:ItemType Type=".gif">
              <desktop5:Verb Id="OpenAsSticker" Clsid="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21" />
            </desktop5:ItemType>
          </desktop4:FileExplorerContextMenus>
        </desktop4:Extension>

        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:SurrogateServer DisplayName="Open as sticker handler">
              <com:Class Id="7ad4e2c3-9b5a-4f2e-8c1d-3e5a0b6f4d21"
                Path="StickerShell.comhost.dll"
                ThreadingModel="STA" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>